{
  "name": "@starter/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build ./src/index.ts --target=node --format=esm --outdir=dist",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./subjects": "./src/subjects.ts"
  },
  "dependencies": {
    "@openauthjs/openauth": "^0.4.3",
    "@starter/core": "workspace:*",
    "@starter/database": "workspace:*",
    "hono": "^4.12.14",
    "sst": "4.7.9",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3"
  }
}
